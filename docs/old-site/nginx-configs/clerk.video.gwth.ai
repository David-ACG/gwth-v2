server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name clerk.video.gwth.ai;

    ssl_certificate /etc/ssl/certs/clerk.video.gwth.ai.crt;
    ssl_certificate_key /etc/ssl/private/clerk.video.gwth.ai.key;

    # Basic SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    location / {
        proxy_pass https://frontend-api.clerk.services;
        proxy_ssl_server_name on;
        proxy_ssl_name frontend-api.clerk.services;
        proxy_set_header Host frontend-api.clerk.services;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_redirect off;

        # CORS headers for Clerk
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Authorization, Content-Type";
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name clerk.video.gwth.ai;

    return 301 https://$server_name$request_uri;
}