# ─── GWTH v2 Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# None of these are needed for Phase 1 (mock data development).

# ─── Auth (TBD — provider not yet chosen) ──────────────────────────────────────
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000

# ─── Email: MailerSend (transactional emails) ──────────────────────────────────
# MAILERSEND_API_KEY=
# MAILERSEND_DOMAIN=
# MAILERSEND_FROM_EMAIL=
# MAILERSEND_FROM_NAME=GWTH.ai

# ─── Email: MailerLite (newsletter management) ─────────────────────────────────
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=

# ─── Public (available in browser) ─────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000
