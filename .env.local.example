# GWTH v2 — Environment Variables
# Copy this file to .env.local and fill in the values.
# No env vars are required for Phase 1 (mock data mode).

# ─── Authentication (Phase 2) ─────────────────────────────────────────────────
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email — MailerSend (transactional emails) ──────────────────────────────
# MAILERSEND_API_KEY=
# MAILERSEND_DOMAIN=gwth.ai
# MAILERSEND_FROM_EMAIL=hello@gwth.ai
# MAILERSEND_FROM_NAME=GWTH.ai

# ─── Email — MailerLite (newsletter subscriber management) ──────────────────
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=

# ─── Payments (Phase 2) ──────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Storage (Phase 2) ───────────────────────────────────────────────────────
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Public Config ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://gwth.ai
# NEXT_PUBLIC_APP_NAME=GWTH.ai
