{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    ":automergeMinor",
    ":automergePatch"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["@types/*"],
      "automerge": true
    },
    {
      "groupName": "shadcn dependencies",
      "matchPackagePatterns": ["radix-ui", "class-variance-authority", "clsx", "tailwind-merge"]
    },
    {
      "groupName": "testing",
      "matchPackagePatterns": ["vitest", "@testing-library/*", "@playwright/*", "playwright"]
    },
    {
      "groupName": "linting",
      "matchPackagePatterns": ["eslint*", "@commitlint/*", "lint-staged", "husky", "knip"]
    }
  ]
}
